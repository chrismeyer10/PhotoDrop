%% PhotoDrop — Gesamt State Diagram
%% Pflege: Bei jeder Aufgabe aktualisieren wenn sich Zustaende, Screens oder Flows aendern.
%% Zeigt: App-Navigation, Screen-Zustaende, DriveViewModel-Zustaende, AgentService-Zustaende.
%% Detail-Diagramme: drive-state-diagram.mmd, navigation-state-diagram.mmd, agent-state-diagram.mmd

stateDiagram-v2
    [*] --> ArchivScreen

    ArchivScreen --> DriveScreen : Drawer
    DriveScreen --> ArchivScreen : Drawer
    ArchivScreen --> EinstellungenScreen : Drawer / Einstellungen-Button
    EinstellungenScreen --> ArchivScreen : Drawer

    state ArchivScreen {
        [*] --> DokBereit
        DokBereit --> DokGeladen : Foto / Datei ausgewaehlt
        DokGeladen --> DokGeladen : Schnellanalyse fertig (Felder befuellt)
        DokGeladen --> DokHochladen : hochladen(dateiname, drivePfad)
        DokGeladen --> DokAnalysiert : Mit KI analysieren
        DokGeladen --> DokBereit : zuruecksetzen()
        DokAnalysiert --> DokVorschlag : KI-Antwort (Dateiname + Drive-Pfad)
        DokAnalysiert --> DokAnalyseFehler : KI-Fehler
        DokAnalyseFehler --> DokManuellBenennen : trotzdemSpeichern()
        DokAnalyseFehler --> DokBereit : zuruecksetzen()
        DokManuellBenennen --> DokHochladen : hochladen(dateiname, drivePfad)
        DokManuellBenennen --> DokBereit : zuruecksetzen()
        DokVorschlag --> DokHochladen : hochladen(dateiname, drivePfad)
        DokHochladen --> DokFertig : Erfolg (mehrstufiger Pfad erstellt)
        DokHochladen --> DokFehler : Fehler
        DokFertig --> DokBereit : Animation abgelaufen (auto) oder Button
        DokFertig --> DriveInhaltNeuLaden : Drive-Ordner aktualisieren
        DokFehler --> DokBereit : zuruecksetzen()
    }

    state DriveScreen {
        [*] --> NichtVerbunden
        NichtVerbunden --> Verbindet : Anmelden
        Verbindet --> OrdnerLaden : Anmeldung OK
        OrdnerLaden --> OrdnerAuswaehlen : Ordner vorhanden
        OrdnerLaden --> OrdnerBenennen : Keine Ordner
        OrdnerAuswaehlen --> Verbunden : Ordner ausgewaehlt
        OrdnerAuswaehlen --> OrdnerBenennen : Neuen Ordner erstellen
        OrdnerAuswaehlen --> NichtVerbunden : Abmelden
        OrdnerBenennen --> Verbindet : Bestaetigen
        OrdnerBenennen --> OrdnerLaden : Abbrechen
        OrdnerBenennen --> NichtVerbunden : Abmelden
        OrdnerLaden --> NichtVerbunden : Abmelden
        Verbindet --> Verbunden : Auto-Reconnect mit Ordner
        Verbindet --> DriveFehler : Fehler
        DriveFehler --> NichtVerbunden : Zuruecksetzen
        Verbunden --> InhaltGeladen : Ordnerinhalt geladen
        Verbunden --> NichtVerbunden : Abmelden
        InhaltGeladen --> NichtVerbunden : Abmelden
        InhaltGeladen --> InhaltGeladen : inhaltNeuLaden() (nach Upload)
        DriveInhaltNeuLaden --> InhaltGeladen : Dateiliste aktualisiert
    }

    state EinstellungenScreen {
        [*] --> AnbieterAuswaehlen
        AnbieterAuswaehlen --> OcrKostenlos : OcrKostenlos gewaehlt
        AnbieterAuswaehlen --> ClaudeHinweisDialog : Claude gewaehlt (kein Key gespeichert)
        ClaudeHinweisDialog --> ClaudeMitKey : Schliessen
        AnbieterAuswaehlen --> ClaudeMitKey : Claude gewaehlt (Key gespeichert)
        AnbieterAuswaehlen --> GptMiniMitKey : GPT-4o-mini gewaehlt
        ClaudeMitKey --> VerbindungsTest : Speichern & testen
        GptMiniMitKey --> VerbindungsTest : Speichern & testen
        VerbindungsTest --> TestErgebnis : Ergebnis (Erfolg oder 401/403/Netz)
        TestErgebnis --> AnbieterAuswaehlen : OK
        ClaudeMitKey --> AnbieterAuswaehlen : Key loeschen
        GptMiniMitKey --> AnbieterAuswaehlen : Key loeschen
    }

    state AgentService {
        [*] --> Bereit
        Bereit --> Laeuft : run()
        Laeuft --> Erfolgreich : Success
        Laeuft --> AgentFehler : Error
        Erfolgreich --> Bereit
        AgentFehler --> Bereit
    }

    state SchnellAktionsLeiste {
        [*] --> SchnellBereit
        SchnellBereit --> SchnellFotoNehmen : Foto-Button (Kamera-Erlaubnis OK)
        SchnellBereit --> SchnellOrdnerWaehlen : Ordner-Button
        SchnellFotoNehmen --> SchnellUploadLaedt : Foto aufgenommen
        SchnellUploadLaedt --> SchnellUploadFertig : Upload Erfolg
        SchnellUploadLaedt --> SchnellUploadFehler : Upload Fehler
        SchnellUploadFertig --> SchnellBereit : Overlay ausgeblendet (auto)
        SchnellUploadFehler --> SchnellBereit : zuruecksetzen()
        SchnellOrdnerWaehlen --> DriveScreen : Navigation
    }
