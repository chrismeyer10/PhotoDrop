%% PhotoDrop — State Diagram
%% Pflege: Bei jeder Aufgabe aktualisieren wenn sich Zustände, Screens oder Flows ändern.
%% Zeigt: App-Navigation, Screen-Zustände, DriveViewModel-Zustände, AgentService-Zustände.

stateDiagram-v2
    [*] --> FotoAufnahmeScreen

    FotoAufnahmeScreen --> DriveScreen : Drawer
    FotoAufnahmeScreen --> DriveScreen : Ordner fehlt
    DriveScreen --> FotoAufnahmeScreen : Drawer

    state FotoAufnahmeScreen {
        [*] --> FotoListe
        FotoListe --> OrdnerDialog : Kamera ohne Ordner
        FotoListe --> KameraOffen : Kamera mit Ordner
        OrdnerDialog --> FotoListe : Abbrechen
        KameraOffen --> FotoListe : Foto gespeichert
    }

    state DriveScreen {
        [*] --> NichtVerbunden
        NichtVerbunden --> Verbindet : Anmelden
        Verbindet --> OrdnerLaden : Anmeldung OK
        OrdnerLaden --> OrdnerAuswaehlen : Ordner vorhanden
        OrdnerLaden --> OrdnerBenennen : Keine Ordner im Drive
        OrdnerAuswaehlen --> Verbunden : Ordner ausgewählt
        OrdnerAuswaehlen --> OrdnerBenennen : Neuen Ordner erstellen
        OrdnerBenennen --> Verbindet : Bestätigen
        Verbindet --> Verbunden : Ordner-ID gespeichert (Auto-Reconnect)
        Verbindet --> DriveFehler : Fehler
        DriveFehler --> NichtVerbunden : Zuruecksetzen
        Verbunden --> InhaltGeladen : Ordnerinhalt geladen
        Verbunden --> NichtVerbunden : Abmelden
        InhaltGeladen --> NichtVerbunden : Abmelden
    }

    state AgentService {
        [*] --> Bereit
        Bereit --> Laeuft : run()
        Laeuft --> Erfolgreich : Success
        Laeuft --> AgentFehler : Error
        Erfolgreich --> Bereit
        AgentFehler --> Bereit
    }
